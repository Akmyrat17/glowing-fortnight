# Root .env example for runtime overrides and secrets
# Keep sensitive values out of configs/config.yaml.
# Docker Compose project name override:
COMPOSE_PROJECT_NAME=boilerplate

SERVER_PORT=8080
SERVER_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=boilerplate
DATABASE_SSLMODE=disable

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=your-secret-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRATION=30m
JWT_REFRESH_TOKEN_EXPIRATION=168h

EXTERNAL_BALTEKAPIKEY=
EXTERNAL_GOOGLE_CLIENT_ID=
EXTERNAL_GOOGLE_CLOUD_STORAGE_BUCKET_NAME=yedu-dev
EXTERNAL_GOOGLE_CLOUD_STORAGE_BASE_URL=https://storage.googleapis.com/yedu-dev
EXTERNAL_GOOGLE_CLOUD_STORAGE_CREDENTIALS_FILE=./configs/firebase-credentials.json
EXTERNAL_TWILIO_KEY=
EXTERNAL_TWILIO_SID=

FIREBASE_CREDENTIALS_FILE=./configs/firebase-credentials.json
